# ── AI provider ──────────────────────────────────────────────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Model used for repository analysis (cost/quality tradeoff)
ANALYSIS_MODEL=claude-sonnet-4-6
# Model used for the RAG chat assistant
CHAT_MODEL=claude-sonnet-4-6

# ── GitHub ───────────────────────────────────────────────────
# Optional but strongly recommended: raises rate limit from 60 -> 5000 req/hr.
# Create a classic token with `public_repo` scope at
# https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Database (Postgres) ──────────────────────────────────────
# Free option: Neon (https://neon.tech) or Vercel Postgres. Both give you a
# pooled URL and a direct URL — paste them here (and into Vercel env vars).
#   DATABASE_URL = pooled connection (ends with ...-pooler... / ?pgbouncer=true)
#   DIRECT_URL   = direct connection (used by `prisma db push` / migrations)
# If your provider gives only one URL, set both to the same value.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"
