# ── AI provider ──────────────────────────────────────────────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Model used for repository analysis (cost/quality tradeoff)
ANALYSIS_MODEL=claude-sonnet-4-6
# Model used for the RAG chat assistant
CHAT_MODEL=claude-sonnet-4-6

# ── GitHub ───────────────────────────────────────────────────
# Optional but strongly recommended: raises rate limit from 60 -> 5000 req/hr.
# Create a classic token with `public_repo` scope at
# https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Database ─────────────────────────────────────────────────
# Dev default: SQLite. For prod swap to Postgres + pgvector:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/repomind"
# and set provider="postgresql" in prisma/schema.prisma
DATABASE_URL="file:./dev.db"
