// RepoMind AI — data model
// Postgres (e.g. Neon, Vercel Postgres, Supabase). Works the same locally and
// on Vercel. `directUrl` is used for schema sync / migrations when DATABASE_URL
// points at a connection pooler (pgbouncer); set both from your provider. The
// instance can later enable pgvector for the RAG embedding store. JSON blobs
// are stored as TEXT for portability.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AnalysisStatus {
  PENDING
  CLONING
  ANALYZING
  COMPLETED
  FAILED
}

model Analysis {
  id        String   @id @default(cuid())
  repoUrl   String
  owner     String
  name      String
  status    String   @default("PENDING") // see AnalysisStatus
  error     String?

  // Denormalized repo metadata for fast list rendering
  description String?
  stars       Int     @default(0)
  forks       Int     @default(0)
  primaryLang String?
  fileCount   Int     @default(0)

  // Full structured analysis payload (AnalysisResult), serialized as JSON text.
  result String?

  messages  ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([owner, name])
  @@index([createdAt])
}

model ChatMessage {
  id         String   @id @default(cuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now())

  @@index([analysisId])
}
